{
  "manifest_version": 3,
  "name": "Secretário Escolar — Agente IA",
  "version": "1.0.0",
  "description": "Agente autônomo que faz atividades escolares no seu Chrome",
  "permissions": ["tabs", "scripting", "storage", "activeTab", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://nova-pasta-secretario.vercel.app/*",
        "http://localhost:5173/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Secretário Escolar"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
